    <item>
      <title>Hugo &#43; PaperMod &#43; 播放列表 &#43; 动画效果</title>
      <link>http://localhost:1313/posts/hello-hugo/</link>
      <pubDate>Thu, 19 Mar 2026 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/posts/hello-hugo/</guid>
      <description>&lt;p&gt;欢迎来到我的博客示例文章，这是我用 &lt;strong&gt;Hugo + Caddy&lt;/strong&gt; 搭建的博客 🚀
这篇文章展示了 &lt;strong&gt;全站播放列表&lt;/strong&gt; 和 &lt;strong&gt;Apple 官网风格动画&lt;/strong&gt;。&lt;/p&gt;
&lt;h2 id=&#34;图片示例&#34;&gt;图片示例&lt;/h2&gt;
&lt;p&gt;&lt;img alt=&#34;奥洛乌佩纳瀑布&#34; loading=&#34;lazy&#34; src=&#34;http://localhost:1313/images/%E5%A5%A5%E6%B4%9B%E4%B9%8C%E4%BD%A9%E7%BA%B3%E7%80%91%E5%B8%83.jpg&#34;&gt;&lt;/p&gt;
&lt;h2 id=&#34;播放列表示例&#34;&gt;播放列表示例&lt;/h2&gt;
&lt;link rel=&#34;stylesheet&#34; href=&#34;https://unpkg.com/aplayer/dist/APlayer.min.css&#34;&gt;
&lt;script src=&#34;https://unpkg.com/aplayer/dist/APlayer.min.js&#34;&gt;&lt;/script&gt;


&lt;div id=&#34;aplayer&#34; style=&#34;height: 300px;&#34;&gt;&lt;/div&gt;

&lt;script&gt;
const ap = new APlayer({
    container: document.getElementById(&#39;aplayer&#39;),
    istFolded: false,
    listMaxHeight: 300,
    audio: [{&#34;artist&#34;:&#34;周笔畅&#34;,&#34;cover&#34;:&#34;/music/周笔畅-最美的期待.jpg&#34;,&#34;name&#34;:&#34;最美的期待&#34;,&#34;url&#34;:&#34;/music/周笔畅-最美的期待.mp3&#34;},{&#34;artist&#34;:&#34;Electric Youth&#34;,&#34;cover&#34;:&#34;/music/Electric Youth-WeAreTheYouth.jpg&#34;,&#34;name&#34;:&#34;WeAreTheYouth&#34;,&#34;url&#34;:&#34;/music/Electric Youth-WeAreTheYouth.mp3&#34;}],
    theme: &#39;#1db954&#39;      
});
&lt;/script&gt;

&lt;style&gt;
 
.aplayer-pic {
  width: 300px !important;
  height: 300px !important;
}

 
.aplayer-title,
.aplayer-author {
  font-size: 1.1rem !important;
}

 
.aplayer-list {
  max-height: 300px !important;
}

 
.aplayer {
  height: 300px !important;
}
&lt;/style&gt;
&lt;h2 id=&#34;动画效果示例&#34;&gt;动画效果示例&lt;/h2&gt;
&lt;div class=&#34;fade-up&#34;&gt;
这里是第一段带淡入动画的内容。  
可以滚动到这里时自动显示。
&lt;/div&gt;
&lt;div class=&#34;fade-up&#34;&gt;
这里是第二段带淡入动画的内容。  
同样会在滚动到可视区域时淡入。
&lt;/div&gt;
